<div class="mx-auto md:w-2/3 w-full">
  <h1 class="text-4xl font-bold mb-6 text-gray-700">Sign Up</h1>

  <%= form_with model: @user, class: "space-y-5" do |form| %>
    <% if @user.errors.any? %>
      <div class="bg-red-100 text-red-700 p-4 rounded">
        <h2 class="font-semibold">
          <%= pluralize(@user.errors.count, "error") %> prevented this account from being created:
        </h2>
        <ul class="list-disc ml-6">
          <% @user.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :email_address, class: "block font-semibold text-gray-700 mb-2" %>
      <%= form.email_field :email_address,
          class: "w-full border border-gray-400 rounded px-4 py-2 text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
    </div>

    <div>
      <%= form.label :password, class: "block font-semibold text-gray-700 mb-2" %>
      <%= form.password_field :password,
          class: "w-full border border-gray-400 rounded px-4 py-2 text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
    </div>

    <div>
      <%= form.label :password_confirmation, class: "block font-semibold text-gray-700 mb-2" %>
      <%= form.password_field :password_confirmation,
          class: "w-full border border-gray-400 rounded px-4 py-2 text-gray-700 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:border-purple-500" %>
    </div>

    <div>
      <%= form.submit "Create Account",
          class: "rounded-md px-6 py-3 font-medium cursor-pointer shadow-sm border border-purple-700",
          style: "background-color:#9333ea; color:white;" %>
    </div>
  <% end %>
</div>