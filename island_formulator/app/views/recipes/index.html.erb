<% content_for :title, "Recipes" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-700 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-extrabold text-slate-100">Recipes</h1>
    <%= link_to "New recipe", new_recipe_path, class: "rounded-xl px-4 py-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold" %>
  </div>

  <% if @recipes.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      <% @recipes.each do |recipe| %>
        <%= render recipe %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-slate-900/40 border border-white/10 rounded-2xl p-10 text-center">
      <p class="text-slate-200 text-xl font-semibold">No recipes yet.</p>
      <p class="text-slate-400 mt-2">Create one and log batches when you make it.</p>
      <div class="mt-6">
        <%= link_to "Create your first recipe", new_recipe_path, class: "rounded-xl px-5 py-3 bg-blue-600 hover:bg-blue-500 text-white font-semibold" %>
      </div>
    </div>
  <% end %>
</div>