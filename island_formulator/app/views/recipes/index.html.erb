<% content_for :title, "Recipes" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="flex items-center justify-between mb-10">
    <h1 class="text-5xl font-bold text-[#B8C7FF]">Recipes</h1>

    <%= link_to "New recipe", new_recipe_path,
      class: "bg-blue-600 hover:bg-blue-500 text-white font-semibold px-6 py-3 rounded-xl shadow-md transition duration-200" %>
  </div>

  <% if @recipes.empty? %>
    <div class="text-center py-12 bg-white/5 rounded-2xl border border-white/10">
      <p class="text-gray-300 mb-4">You haven’t created any recipes yet.</p>
      <%= link_to "Create your first recipe", new_recipe_path,
        class: "text-purple-300 hover:underline font-semibold" %>
    </div>
  <% else %>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <% @recipes.each do |recipe| %>
        <div class="bg-[#EEF1FF] rounded-[3rem] border-4 border-[#9E7BB5] overflow-hidden shadow-lg">
          <!-- Photo (optional) -->
          <% if recipe.photo.attached? %>
            <%= image_tag recipe.photo, class: "w-full h-48 object-cover" %>
          <% else %>
            <div class="w-full h-48 bg-gray-200 flex items-center justify-center text-gray-500">
              No photo
            </div>
          <% end %>

          <div class="p-8">
            <!-- Product type badge -->
            <div class="inline-flex items-center px-4 py-1 rounded-full bg-[#E5D4FF] text-[#3B1B5A] text-xs font-bold uppercase tracking-wide">
              <%= recipe.product_type.presence || "Recipe" %>
            </div>

            <!-- Title -->
            <h2 class="text-2xl font-bold text-[#24114A] mt-4">
              <%= recipe.title %>
            </h2>

            <!-- Sub info -->
            <p class="text-sm text-gray-600 mt-2">
              <%= pluralize(recipe.ingredients.count, "ingredient") %>
            </p>

            <!-- Method preview -->
            <p class="text-gray-700 mt-4">
              <%= truncate(recipe.method.to_s, length: 120) %>
            </p>

            <div class="border-t border-[#D9C2F2] mt-6 pt-4 flex items-center justify-between">
              <%= link_to "View", recipe_path(recipe), class: "text-purple-700 font-semibold hover:underline" %>

              <div class="flex gap-3">
                <%= link_to "Edit", edit_recipe_path(recipe),
                  class: "px-4 py-2 rounded-xl bg-[#9E7BB5] text-white font-semibold hover:brightness-110 transition" %>

                <%= button_to "Delete", recipe_path(recipe),
                  method: :delete,
                  data: { turbo_confirm: "Are you sure?" },
                  class: "px-4 py-2 rounded-xl bg-[#630436] text-white font-semibold hover:brightness-125 transition" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>