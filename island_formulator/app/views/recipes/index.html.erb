<% content_for :title, "Recipes" %>

<div class="container mx-auto mt-12 px-6">
  <div class="flex justify-between items-center mb-12">
    <h1 class="text-5xl font-extrabold text-indigo-300 tracking-wide">
      Recipes
    </h1>

    <%= link_to "Add New Recipe", new_recipe_path,
      class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-3 px-6 rounded-full shadow-md transition duration-200" %>
  </div>

  <% if notice.present? %>
    <p class="mb-6 text-indigo-700 font-medium"><%= notice %></p>
  <% end %>

  <% if @recipes.any? %>
    <!-- Wider tiles: 2 columns on md+ screens (instead of 3 on lg) -->
    <div id="recipes" class="grid grid-cols-1 md:grid-cols-2 gap-10 pb-24">
      <% @recipes.each do |recipe| %>

        <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8
                    rounded-[60px] relative hover:shadow-2xl transition duration-300">

          <div class="flex justify-between items-start gap-6">

            <!-- LEFT: Text -->
            <div class="flex-1 min-w-0">
              <div class="mb-4">
                <span class="inline-block px-4 py-1 text-xs font-semibold
                             text-indigo-800 uppercase bg-purple-200 rounded-full">
                  <%= recipe.product_type.presence || "RECIPE" %>
                </span>
              </div>

              <h2 class="text-2xl font-bold text-indigo-900 mb-3 truncate">
                <%= recipe.title %>
              </h2>

              <p class="text-gray-600 mb-6">
                <%= recipe.method.present? ? truncate(recipe.method, length: 90) : "No method added yet." %>
              </p>

              <div class="flex justify-between items-center border-t-2 border-purple-200 pt-4">
                <%= link_to "View", recipe,
                  class: "text-purple-600 font-medium hover:text-indigo-800" %>
              </div>
            </div>

            <!-- RIGHT: Image (slightly smaller to give text more room) -->
            <div class="w-28 h-28 flex-shrink-0">
              <% if recipe.photo.attached? %>
                <%= image_tag recipe.photo,
                  class: "w-28 h-28 object-cover rounded-[28px] shadow-md border-2 border-purple-200" %>
              <% else %>
                <div class="w-28 h-28 rounded-[28px] bg-purple-100 border-2 border-purple-200
                            flex items-center justify-center text-purple-300 text-sm font-semibold">
                  No Image
                </div>
              <% end %>
            </div>

          </div>
        </div>

      <% end %>
    </div>
  <% else %>
    <div class="bg-indigo-50 border-4 border-purple-200 shadow-lg p-10 rounded-[40px] text-center">
      <p class="text-indigo-900 text-xl font-bold">No recipes yet.</p>
      <p class="text-gray-600 mt-2">Create one and start logging batches.</p>

      <div class="mt-6">
        <%= link_to "Create your first recipe", new_recipe_path,
          class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-3 px-6 rounded-full shadow-md transition duration-200 inline-block" %>
      </div>
    </div>
  <% end %>
</div>