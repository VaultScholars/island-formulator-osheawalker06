<div class="bg-slate-900/60 border border-purple-300/20 rounded-2xl shadow-lg overflow-hidden">
  <% if recipe.photo.attached? %>
    <%= image_tag recipe.photo, class: "w-full h-64 object-cover" %>
  <% else %>
    <div class="w-full h-64 bg-slate-900/80 border-b border-white/10 flex items-center justify-center">
      <p class="text-slate-400">No photo</p>
    </div>
  <% end %>

  <div class="p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-widest text-slate-300"><%= recipe.product_type %></p>
        <h3 class="text-xl font-extrabold text-slate-100 mt-1"><%= recipe.title %></h3>
        <p class="text-slate-400 text-sm mt-1">
          <%= pluralize(recipe.recipe_ingredients.size, "ingredient") %>
        </p>
      </div>
    </div>

    <div class="mt-5 flex gap-2">
      <%= link_to "View", recipe_path(recipe), class: "rounded-lg px-3 py-2 bg-white/10 hover:bg-white/15 text-slate-100 font-semibold" %>
      <%= link_to "Edit", edit_recipe_path(recipe), class: "rounded-lg px-3 py-2 bg-purple-500/20 hover:bg-purple-500/30 text-slate-100 font-semibold" %>
      <%= button_to "Delete", recipe, method: :delete,
        class: "rounded-lg px-3 py-2 bg-red-600/80 hover:bg-red-600 text-white font-semibold",
        data: { turbo_confirm: "Delete this recipe?" } %>
    </div>
  </div>
</div>