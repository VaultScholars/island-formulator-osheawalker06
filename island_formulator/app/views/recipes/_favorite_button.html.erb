<% if current_user && recipe.present? %>
  <% if current_user.favorited?(recipe) %>
    <%= button_to recipe_favorite_path(recipe),
      method: :delete,
      form_class: "inline",
      class: "w-12 h-12 rounded-full bg-white border-2 border-red-200 shadow-lg flex items-center justify-center hover:scale-110 transition duration-200" do %>
      <svg xmlns="http://www.w3.org/2000/svg"
           viewBox="0 0 24 24"
           fill="currentColor"
           class="w-7 h-7 text-red-500">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5
                 2 5.42 4.42 3 7.5 3
                 9.24 3 10.91 3.81 12 5.09
                 13.09 3.81 14.76 3 16.5 3
                 19.58 3 22 5.42 22 8.5
                 c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
    <% end %>
  <% else %>
    <%= button_to recipe_favorite_path(recipe),
      method: :post,
      form_class: "inline",
      class: "w-12 h-12 rounded-full bg-[#311432] border-2 border-purple-300 shadow-lg flex items-center justify-center hover:scale-110 transition duration-200" do %>
      <svg xmlns="http://www.w3.org/2000/svg"
           viewBox="0 0 24 24"
           fill="currentColor"
           class="w-7 h-7 text-white">
        <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5
                 2 5.42 4.42 3 7.5 3
                 9.24 3 10.91 3.81 12 5.09
                 13.09 3.81 14.76 3 16.5 3
                 19.58 3 22 5.42 22 8.5
                 c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
      </svg>
    <% end %>
  <% end %>
<% end %>