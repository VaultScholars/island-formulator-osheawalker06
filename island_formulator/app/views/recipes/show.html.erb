<% content_for :title, "Showing recipe" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p
      class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block"
      id="notice"
    >
      <%= notice %>
    </p>
  <% end %>

  <% if @recipe.photo.attached? %>
    <%= image_tag @recipe.photo, class: "w-full max-w-md h-64 object-cover rounded-xl mb-6" %>
  <% end %>

  <h1 class="font-bold text-4xl mb-6"><%= @recipe.title %></h1>

  <p class="mb-4 text-gray-600">
    <strong>Product Type:</strong> <%= @recipe.product_type %>
  </p>

  <div class="mb-6">
    <p class="font-semibold mb-2">Method:</p>
    <div class="prose max-w-none">
      <%= simple_format(@recipe.method) %>
    </div>
  </div>

  <h2 class="text-2xl font-semibold mb-4">Ingredients</h2>

  <ul class="space-y-2 mb-8">
    <% @recipe.recipe_ingredients.each do |ri| %>
      <li class="bg-gray-100 p-3 rounded-lg">
        <span class="font-semibold"><%= ri.quantity %></span>
        <span class="mx-1">—</span>
        <%= ri.ingredient.name %>
      </li>
    <% end %>
  </ul>

  <div class="flex flex-wrap gap-4">
    <%= link_to "Edit", edit_recipe_path(@recipe),
      class: "px-6 py-3 bg-[#9E7BB5] text-white rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

    <%= link_to "Back", recipes_path,
      class: "px-6 py-3 bg-gray-200 rounded-xl font-semibold shadow-md hover:bg-gray-300 transition duration-200" %>

    <%= link_to "Log a New Batch", new_batch_path(recipe_id: @recipe.id),
  class: "rounded-lg py-3 px-5 bg-green-600 text-white block font-medium" %>

    <%= button_to "Destroy", @recipe,
      method: :delete,
      data: { turbo_confirm: "Are you sure?" },
      class: "px-6 py-3 bg-red-600 text-white rounded-xl font-semibold shadow-md hover:bg-red-500 transition duration-200" %>
  </div>
</div>
