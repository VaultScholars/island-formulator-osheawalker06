<% content_for :title, "Recipe View" %>

<div class="md:w-2/3 w-full">
  <% if @recipe.photo.attached? %>
    <%= image_tag @recipe.photo, class: "w-full max-w-md h-64 object-cover rounded-xl mb-6" %>
  <% end %>

  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="flex items-start justify-between gap-4 mb-6">
    <h1 class="font-bold text-gray-700 text-4xl"><%= @recipe.title %></h1>

    <% if current_user.favorited?(@recipe) %>
      <%= button_to "❤️", recipe_favorite_path(@recipe),
        method: :delete,
        form_class: "inline-block",
        class: "text-3xl bg-transparent border-0 p-0 hover:scale-110 transition duration-200 cursor-pointer" %>
    <% else %>
      <%= button_to "🤍", recipe_favorite_path(@recipe),
        method: :post,
        form_class: "inline-block",
        class: "text-3xl bg-transparent border-0 p-0 hover:scale-110 transition duration-200 cursor-pointer" %>
    <% end %>
  </div>

  <div class="space-y-6 text-gray-600">
    <div>
      <strong class="block font-medium mb-1 text-gray-700">Title:</strong>
      <%= @recipe.title %>
    </div>

    <div>
      <strong class="block font-medium mb-1 text-gray-700">Product Type:</strong>
      <%= @recipe.product_type %>
    </div>

    <div>
      <strong class="block font-medium mb-1 text-gray-700">Method:</strong>
      <div class="prose max-w-none">
        <%= simple_format(@recipe.method) %>
      </div>
    </div>

    <div>
      <strong class="block font-medium mb-3 text-gray-700">Ingredients:</strong>

      <ul class="space-y-2">
        <% @recipe.recipe_ingredients.each do |ri| %>
          <li class="bg-gray-100 p-3 rounded-lg">
            <span class="font-semibold"><%= ri.quantity %></span>
            <span class="mx-1">—</span>
            <%= ri.ingredient.name %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>

  <div class="flex items-center gap-6 mt-8 flex-wrap">
    <%= link_to "Edit this recipe", edit_recipe_path(@recipe),
      class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

    <%= link_to "Back to recipes", recipes_path,
      class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

    <%= link_to "Log a new batch", new_batch_path(recipe_id: @recipe.id),
      class: "bg-[#311432] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

    <%= button_to "Destroy this recipe", @recipe,
      method: :delete,
      form_class: "inline",
      data: { turbo_confirm: "Are you sure?" },
      class: "bg-[#630436] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-125 transition duration-200" %>
  </div>
</div>