<%= form_with(model: recipe, class: "contents") do |form| %>
  <% if recipe.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-700 px-4 py-3 rounded-md mb-6">
      <h2 class="font-bold mb-2">
        <%= pluralize(recipe.errors.count, "error") %> prohibited this recipe from being saved:
      </h2>
      <ul class="list-disc ml-6">
        <% recipe.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- PHOTO UPLOAD -->
  <div class="my-4">
    <%= form.label :photo, "Recipe Photo", class: "block font-medium mb-2 text-gray-700" %>

    <%= form.file_field :photo,
      class: "block w-full text-gray-700 text-sm
              file:mr-4 file:py-2 file:px-4
              file:rounded-md file:border-0
              file:text-sm file:font-semibold
              file:bg-gray-100 file:text-black
              hover:file:bg-gray-200" %>

    <% if recipe.photo.attached? %>
      <div class="mt-4">
        <%= image_tag recipe.photo, class: "w-full max-w-md h-56 object-cover rounded-2xl border-2 border-[#9E7BB5] shadow-md" %>
        <p class="text-gray-600 text-sm mt-2">Current photo</p>
      </div>
    <% end %>
  </div>

  <div class="space-y-6">
    <!-- TITLE -->
    <div>
      <%= form.label :title, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :title,
        placeholder: "e.g. Coconut Oil Blend",
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- PRODUCT TYPE -->
    <div>
      <%= form.label :product_type, "Product type", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :product_type,
        placeholder: "e.g. Oil / Butter / Serum",
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- METHOD -->
    <div>
      <%= form.label :method, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_area :method, rows: 5,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- INGREDIENTS (nested) -->
    <div data-controller="nested-form">
      <div class="flex items-center justify-between mb-2">
        <p class="block text-sm font-semibold text-gray-700">Ingredients</p>

        <button type="button"
                data-action="nested-form#add"
                class="bg-[#9E7BB5] text-white px-4 py-2 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200">
          + Add ingredient
        </button>
      </div>

      <!-- Template for NEW ingredient rows -->
      <template data-nested-form-target="template">
        <%= form.fields_for :recipe_ingredients, RecipeIngredient.new, child_index: "NEW_RECORD" do |ri_form| %>
          <div data-nested-form-wrapper class="grid grid-cols-1 md:grid-cols-12 gap-3 items-end bg-gray-100 border-2 border-[#9E7BB5] rounded-2xl p-4 shadow-md">
            <div class="md:col-span-6">
              <%= ri_form.label :ingredient_id, "Ingredient", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= ri_form.collection_select :ingredient_id,
                current_user.ingredients, :id, :name,
                { prompt: "Select Ingredient" },
                { class: "block w-full rounded-2xl bg-white text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" } %>
            </div>

            <div class="md:col-span-4">
              <%= ri_form.label :quantity, class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= ri_form.text_field :quantity,
                placeholder: "e.g. 100ml",
                class: "block w-full rounded-2xl bg-white text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
            </div>

            <div class="md:col-span-2"></div>
          </div>
        <% end %>
      </template>

      <!-- Existing rows -->
      <div class="space-y-3" data-nested-form-target="target">
        <%= form.fields_for :recipe_ingredients do |ri_form| %>
          <div data-nested-form-wrapper class="grid grid-cols-1 md:grid-cols-12 gap-3 items-end bg-gray-100 border-2 border-[#9E7BB5] rounded-2xl p-4 shadow-md">
            <div class="md:col-span-6">
              <%= ri_form.label :ingredient_id, "Ingredient", class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= ri_form.collection_select :ingredient_id,
                current_user.ingredients, :id, :name,
                { prompt: "Select Ingredient" },
                { class: "block w-full rounded-2xl bg-white text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" } %>
            </div>

            <div class="md:col-span-4">
              <%= ri_form.label :quantity, class: "block text-sm font-semibold text-gray-700 mb-2" %>
              <%= ri_form.text_field :quantity,
                placeholder: "e.g. 100ml",
                class: "block w-full rounded-2xl bg-white text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-sm focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
            </div>

            <div class="md:col-span-2"></div>
          </div>
        <% end %>
      </div>
    </div>

    <!-- ACTIONS -->
    <div class="flex flex-wrap items-center gap-4 pt-2">
      <%= form.submit(
        recipe.persisted? ? "Update Recipe" : "Create Recipe",
        class: "bg-[#311432] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200"
      ) %>

      <% if recipe.persisted? %>
        <%= link_to "Show this recipe", recipe,
          class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>
      <% end %>

      <%= link_to "Back to recipes", recipes_path,
        class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>
    </div>
  </div>
<% end %>