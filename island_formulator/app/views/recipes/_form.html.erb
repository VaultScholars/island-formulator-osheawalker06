<%= form_with(model: recipe, class: "contents") do |form| %>
  <% if recipe.errors.any? %>
    <div class="bg-red-50 text-red-700 px-4 py-3 rounded-xl mb-6">
      <h2 class="font-semibold">
        <%= pluralize(recipe.errors.count, "error") %> prevented this recipe from being saved:
      </h2>
      <ul class="list-disc ml-6 mt-2">
        <% recipe.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left: Main fields -->
    <div class="lg:col-span-2 bg-slate-900/40 border border-white/10 rounded-2xl shadow-lg p-6">
      <h2 class="text-2xl font-extrabold text-slate-100 mb-6">Recipe Details</h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <%= form.label :title, class: "block text-slate-200 font-semibold mb-2" %>
          <%= form.text_field :title,
            placeholder: "e.g. Coconut Oil Blend",
            class: "w-full bg-slate-900/60 text-slate-100 placeholder:text-slate-400 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-purple-400/40" %>
        </div>

        <div>
          <%= form.label :product_type, "Product type", class: "block text-slate-200 font-semibold mb-2" %>
          <%= form.text_field :product_type,
            placeholder: "e.g. Oil / Butter / Serum",
            class: "w-full bg-slate-900/60 text-slate-100 placeholder:text-slate-400 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-purple-400/40" %>
        </div>
      </div>

      <div class="mt-5">
        <%= form.label :method, class: "block text-slate-200 font-semibold mb-2" %>
        <%= form.text_area :method,
          rows: 8,
          placeholder: "Write your method here (steps, temps, notes, etc.)",
          class: "w-full bg-slate-900/60 text-slate-100 placeholder:text-slate-400 border border-white/10 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-purple-400/40" %>
      </div>
    </div>

    <!-- Right: Photo -->
    <div class="bg-slate-900/40 border border-white/10 rounded-2xl shadow-lg p-6">
      <h2 class="text-2xl font-extrabold text-slate-100 mb-6">Photo</h2>

      <%= form.label :photo, "Recipe photo", class: "block text-slate-200 font-semibold mb-2" %>
      <%= form.file_field :photo,
        class: "block w-full text-sm text-slate-200
               file:mr-4 file:py-2 file:px-4
               file:rounded-xl file:border-0 file:text-sm file:font-semibold
               file:bg-white/10 file:text-slate-100 hover:file:bg-white/15" %>

      <% if recipe.photo.attached? %>
        <div class="mt-5">
          <%= image_tag recipe.photo, class: "w-full h-56 object-cover rounded-2xl border border-white/10" %>
          <p class="text-slate-400 text-sm mt-2">Current photo</p>
        </div>
      <% else %>
        <div class="mt-5 bg-slate-900/60 border border-white/10 rounded-2xl p-6 text-center">
          <p class="text-slate-300">No photo uploaded yet.</p>
          <p class="text-slate-500 text-sm mt-1">Add one to make your recipe cards pop.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Ingredients -->
  <div class="mt-6 bg-slate-900/40 border border-white/10 rounded-2xl shadow-lg p-6">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-2xl font-extrabold text-slate-100">Ingredients</h2>
      <p class="text-slate-400 text-sm">Select an ingredient and enter a quantity.</p>
    </div>

    <div class="space-y-3">
      <%= form.fields_for :recipe_ingredients do |ri_form| %>
        <div class="grid grid-cols-1 md:grid-cols-12 gap-3 items-center bg-slate-900/60 border border-white/10 rounded-2xl p-4">
          <div class="md:col-span-6">
            <%= ri_form.label :ingredient_id, "Ingredient", class: "block text-slate-300 text-sm mb-1" %>
            <%= ri_form.collection_select :ingredient_id,
              current_user.ingredients,
              :id,
              :name,
              { prompt: "Select Ingredient" },
              { class: "w-full bg-slate-900/60 text-slate-100 border border-white/10 rounded-xl px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-400/40" } %>
          </div>

          <div class="md:col-span-4">
            <%= ri_form.label :quantity, class: "block text-slate-300 text-sm mb-1" %>
            <%= ri_form.text_field :quantity,
              placeholder: "e.g. 100ml",
              class: "w-full bg-slate-900/60 text-slate-100 placeholder:text-slate-400 border border-white/10 rounded-xl px-3 py-2 focus:outline-none focus:ring-2 focus:ring-purple-400/40" %>
          </div>

          <div class="md:col-span-2 flex items-center gap-2 mt-2 md:mt-6">
            <%= ri_form.check_box :_destroy, class: "h-4 w-4 rounded border-white/20 bg-slate-900/60" %>
            <%= ri_form.label :_destroy, "Remove", class: "text-slate-300 text-sm" %>
          </div>
        </div>
      <% end %>
    </div>

    <p class="text-slate-500 text-sm mt-4">
      Tip: If you need more ingredient rows, increase how many <code class="text-slate-300">recipe_ingredients.build</code>
      you do in the controller (usually in <code class="text-slate-300">new</code>).
    </p>
  </div>

  <!-- Actions -->
  <div class="mt-6 flex flex-wrap gap-3">
    <%= form.submit (recipe.persisted? ? "Update Recipe" : "Create Recipe"),
      class: "rounded-xl px-6 py-3 bg-purple-600 hover:bg-purple-500 text-white font-semibold" %>

    <%= link_to "Back to recipes", recipes_path,
      class: "rounded-xl px-6 py-3 bg-white/10 hover:bg-white/15 text-slate-100 font-semibold" %>
  </div>
<% end %>