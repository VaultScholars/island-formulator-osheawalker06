<% content_for :title, "Dashboard" %>

<div class="container mx-auto mt-12 px-6">
  <!-- Header -->
  <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-6 mb-12">
    <div>
      <h1 class="text-5xl font-extrabold text-indigo-300 tracking-wide">
        Dashboard
      </h1>
      <p class="text-indigo-200/80 mt-2"></p>
    </div>

    <!-- Action buttons -->
    <div class="flex flex-wrap justify-center gap-6 w-full px-40">
      <%= link_to "Add Ingredient", new_ingredient_path,
        class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-3 px-6 rounded-full shadow-md transition duration-200" %>

      <%= link_to "Add New Recipe", new_recipe_path,
        class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-3 px-6 rounded-full shadow-md transition duration-200" %>

      <%= link_to "Add Inventory", new_inventory_item_path,
        class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-3 px-6 rounded-full shadow-md transition duration-200" %>

      <%= link_to "Log Batch", new_batch_path,
        class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-3 px-6 rounded-full shadow-md transition duration-200" %>
    </div>
  </div>

  <!-- Favorites card -->
  <div class="mb-14">
    <%= link_to favorites_path,
      class: "block bg-indigo-50 border-4 border-purple-300 rounded-[60px] p-8 shadow-lg hover:shadow-2xl transition duration-300" do %>
      <div class="flex items-center justify-between gap-6">
        <div>
          <h2 class="text-2xl font-bold text-indigo-900 mb-2">Favorite Recipes</h2>
          <p class="text-gray-600">View all the recipes you saved.</p>
        </div>

        <div class="text-3xl">
          ❤️
        </div>
      </div>
    <% end %>
  </div>

  <!-- Flash / notice -->
  <% if notice.present? %>
    <p class="mb-6 text-indigo-700 font-medium"><%= notice %></p>
  <% end %>

  <!-- Stats cards -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10 mb-12">
    <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] hover:shadow-2xl transition duration-300">
      <p class="text-xs font-semibold text-indigo-800 uppercase bg-purple-200 rounded-full inline-block px-4 py-1">
        Ingredients
      </p>
      <p class="text-4xl font-extrabold text-indigo-900 mt-4"><%= @stats[:ingredients] %></p>
      <p class="text-gray-600 mt-2">Total saved</p>
      <div class="mt-6 border-t-2 border-purple-200 pt-4 flex justify-between items-center">
        <%= link_to "View", ingredients_path, class: "text-purple-600 font-medium hover:text-indigo-800" %>
        <span class="text-gray-400 text-sm">#All</span>
      </div>
    </div>

    <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] hover:shadow-2xl transition duration-300">
      <p class="text-xs font-semibold text-indigo-800 uppercase bg-purple-200 rounded-full inline-block px-4 py-1">
        Recipes
      </p>
      <p class="text-4xl font-extrabold text-indigo-900 mt-4"><%= @stats[:recipes] %></p>
      <p class="text-gray-600 mt-2">Formulas created</p>
      <div class="mt-6 border-t-2 border-purple-200 pt-4 flex justify-between items-center">
        <%= link_to "View", recipes_path, class: "text-purple-600 font-medium hover:text-indigo-800" %>
        <span class="text-gray-400 text-sm">#All</span>
      </div>
    </div>

    <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] hover:shadow-2xl transition duration-300">
      <p class="text-xs font-semibold text-indigo-800 uppercase bg-purple-200 rounded-full inline-block px-4 py-1">
        Inventory
      </p>
      <p class="text-4xl font-extrabold text-indigo-900 mt-4"><%= @stats[:inventory] %></p>
      <p class="text-gray-600 mt-2">Purchases tracked</p>
      <div class="mt-6 border-t-2 border-purple-200 pt-4 flex justify-between items-center">
        <%= link_to "View", inventory_items_path, class: "text-purple-600 font-medium hover:text-indigo-800" %>
        <span class="text-gray-400 text-sm">#All</span>
      </div>
    </div>

    <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] hover:shadow-2xl transition duration-300">
      <p class="text-xs font-semibold text-indigo-800 uppercase bg-purple-200 rounded-full inline-block px-4 py-1">
        Batches
      </p>
      <p class="text-4xl font-extrabold text-indigo-900 mt-4"><%= @stats[:batches] %></p>
      <p class="text-gray-600 mt-2">Production logs</p>
      <div class="mt-6 border-t-2 border-purple-200 pt-4 flex justify-between items-center">
        <%= link_to "View", batches_path, class: "text-purple-600 font-medium hover:text-indigo-800" %>
        <span class="text-gray-400 text-sm">#All</span>
      </div>
    </div>
  </div>

  <!-- Recent panels -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 pb-24">
    <!-- Recent Recipes -->
    <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] hover:shadow-2xl transition duration-300">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-indigo-900">Recent Recipes</h2>
        <%= link_to "View all", recipes_path, class: "text-purple-600 font-medium hover:text-indigo-800" %>
      </div>

      <% if @recent_recipes.any? %>
        <div class="space-y-4">
          <% @recent_recipes.each do |recipe| %>
            <div class="bg-white/70 rounded-3xl p-5 flex items-center justify-between">
              <div>
                <p class="text-indigo-900 font-bold"><%= recipe.title %></p>
                <p class="text-gray-600 text-sm"><%= recipe.product_type %></p>
              </div>
              <%= link_to "Open", recipe_path(recipe),
                class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-2 px-5 rounded-full shadow-md transition duration-200" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-600">No recipes yet.</p>
      <% end %>
    </div>

    <!-- Recent Batches -->
    <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] hover:shadow-2xl transition duration-300">
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-2xl font-bold text-indigo-900">Recent Batches</h2>
        <%= link_to "View all", batches_path, class: "text-purple-600 font-medium hover:text-indigo-800" %>
      </div>

      <% if @recent_batches.any? %>
        <div class="space-y-4">
          <% @recent_batches.each do |batch| %>
            <div class="bg-white/70 rounded-3xl p-5 flex items-center justify-between">
              <div>
                <p class="text-indigo-900 font-bold"><%= batch.recipe&.title || "Unknown recipe" %></p>
                <p class="text-gray-600 text-sm">
                  Made on <%= batch.made_on&.strftime("%b %d, %Y") %>
                </p>
              </div>
              <%= link_to "Details", batch_path(batch),
                class: "bg-purple-400 hover:bg-purple-500 text-white font-bold py-2 px-5 rounded-full shadow-md transition duration-200" %>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-gray-600">No batches yet.</p>
      <% end %>
    </div>
  </div>
</div>