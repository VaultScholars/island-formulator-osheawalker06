<%= form_with(model: ingredient, class: "contents") do |form| %>
  <% if ingredient.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-700 px-4 py-3 rounded-md mb-6">
      <h2 class="font-bold mb-2">
        <%= pluralize(ingredient.errors.count, "error") %> prohibited this ingredient from being saved:
      </h2>
      <ul class="list-disc ml-6">
        <% ingredient.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- PHOTO UPLOAD -->
  <div class="my-4">
    <%= form.label :photo, "Ingredient Photo", class: "block font-medium mb-2 text-gray-700" %>

    <%= form.file_field :photo,
      class: "block w-full text-gray-700 text-sm
              file:mr-4 file:py-2 file:px-4
              file:rounded-md file:border-0
              file:text-sm file:font-semibold
              file:bg-gray-100 file:text-black
              hover:file:bg-gray-200" %>

    <% if ingredient.photo.attached? %>
      <div class="mt-4">
        <%= image_tag ingredient.photo, class: "w-full max-w-md h-56 object-cover rounded-2xl border-2 border-[#9E7BB5] shadow-md" %>
        <p class="text-gray-600 text-sm mt-2">Current photo</p>
      </div>
    <% end %>
  </div>

  <div class="space-y-6">
    <!-- NAME -->
    <div>
      <%= form.label :name, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :name,
        placeholder: "e.g. Coconut Oil",
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- CATEGORY -->
    <div>
      <%= form.label :category, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :category,
        placeholder: "e.g. Oil / Butter / Wax",
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- DESCRIPTION -->
    <div>
      <%= form.label :description, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_area :description, rows: 5,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- NOTES -->
    <div>
      <%= form.label :notes, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_area :notes, rows: 5,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- ACTIONS -->
    <div class="flex flex-wrap items-center gap-4 pt-2">
      <%= form.submit(
        ingredient.persisted? ? "Update Ingredient" : "Create Ingredient",
        class: "bg-[#311432] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200"
      ) %>

      <% if ingredient.persisted? %>
        <%= link_to "Show this ingredient", ingredient,
          class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>
      <% end %>

      <%= link_to "Back to ingredients", ingredients_path,
        class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>
    </div>
  </div>
<% end %>