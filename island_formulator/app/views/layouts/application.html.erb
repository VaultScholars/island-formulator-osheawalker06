<!DOCTYPE html>
<html class="min-h-screen">
  <head>
    <title><%= content_for(:title) || "Island Formulator" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      html, body { background: #120c1d !important; }
    </style>
  </head>

  <body class="min-h-screen text-gray-100">
    <header class="bg-purple-400 shadow-xl">
      <div class="max-w-6xl mx-auto px-6 py-10">
        <div class="flex items-center gap-3">
          <span class="text-3xl">🌸</span>
          <div>
            <h1 class="text-4xl md:text-5xl font-extrabold text-indigo-900 leading-tight">
              Island Formulator
            </h1>
            <p class="text-indigo-800 text-lg mt-1">
              Crafting Ingredients with Style
            </p>
          </div>
        </div>
      </div>
    </header>

    <main class="max-w-6xl mx-auto px-6 py-14">
      <nav class="mb-12 px-6 py-4 bg-white border border-gray-200 shadow-sm rounded-2xl">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <div class="flex flex-col sm:flex-row sm:items-center gap-6">
            <% if authenticated? %>
              <div class="flex flex-wrap items-center gap-10">
                <%= link_to "Dashboard", root_path, class: "text-gray-600 hover:text-gray-900 transition-colors" %>
                <%= link_to "My Recipes", recipes_path, class: "text-gray-600 hover:text-gray-900 transition-colors" %>
                <%= link_to "Inventory", inventory_items_path, class: "text-gray-600 hover:text-gray-900 transition-colors" %>
                <%= link_to "Batches", batches_path, class: "text-gray-600 hover:text-gray-900 transition-colors" %>
                <%= link_to "My Ingredients", ingredients_path, class: "text-gray-600 hover:text-gray-900 transition-colors" %>
              </div>
            <% end %>
          </div>

          <div class="flex items-center gap-3">
            <% if authenticated? %>
              <span class="text-sm text-gray-700 bg-gray-100 px-3 py-2 rounded-xl border">
                <%= Current.user.email_address %>
              </span>

              <%= button_to "Logout", session_path, method: :delete,
                class: "px-4 py-2 rounded-xl text-sm text-red-600 hover:text-red-700 hover:bg-red-50 border transition-colors" %>
            <% end %>
          </div>
        </div>
      </nav>

      <div class="bg-white rounded-2xl shadow-xl border border-gray-200 p-8 mb-24">
        <%= yield %>
      </div>
    </main>
  </body>
</html>