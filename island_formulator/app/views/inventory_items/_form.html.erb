<%= form_with(model: inventory_item, class: "contents") do |form| %>
  <% if inventory_item.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-700 px-4 py-3 rounded-md mb-6">
      <h2 class="font-bold mb-2">
        <%= pluralize(inventory_item.errors.count, "error") %> prohibited this inventory item from being saved:
      </h2>
      <ul class="list-disc ml-6">
        <% inventory_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-6">
    <!-- INGREDIENT -->
    <div>
      <%= form.label :ingredient_id, "Ingredient", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.collection_select :ingredient_id, current_user.ingredients, :id, :name,
        { prompt: "Select an ingredient" },
        { class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" } %>
    </div>

    <!-- PURCHASE DATE -->
    <div>
      <%= form.label :purchase_date, "Purchase date", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.date_field :purchase_date,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- BRAND -->
    <div>
      <%= form.label :brand, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :brand,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- SIZE -->
    <div>
      <%= form.label :size, "Size", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :size,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- STORAGE LOCATION -->
    <div>
      <%= form.label :location, "Storage location", class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_field :location,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- NOTES -->
    <div>
      <%= form.label :notes, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.text_area :notes, rows: 5,
        class: "block w-full rounded-2xl bg-gray-100 text-gray-600 border-2 border-[#9E7BB5] px-4 py-3 shadow-md focus:outline-none focus:ring-2 focus:ring-[#9E7BB5]" %>
    </div>

    <!-- PHOTO (only if has_one_attached :photo) -->
    <div>
      <%= form.label :photo, class: "block text-sm font-semibold text-gray-700 mb-2" %>
      <%= form.file_field :photo,
        class: "block w-full text-gray-700 text-sm
                file:mr-4 file:py-2 file:px-4
                file:rounded-md file:border-0
                file:text-sm file:font-semibold
                file:bg-gray-100 file:text-black
                hover:file:bg-gray-200" %>

      <% if inventory_item.photo.attached? %>
        <div class="mt-4">
          <%= image_tag inventory_item.photo, class: "w-full max-w-md h-56 object-cover rounded-2xl border-2 border-[#9E7BB5] shadow-md" %>
          <p class="text-gray-600 text-sm mt-2">Current photo</p>
        </div>
      <% end %>
    </div>

    <!-- ACTIONS -->
    <div class="flex flex-wrap items-center gap-4 pt-2">
      <%= form.submit "Save inventory item",
        class: "bg-[#311432] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

      <%= link_to "Back to inventory items", inventory_items_path,
        class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>
    </div>
  </div>
<% end %>