<%= form_with(model: inventory_item, class: "contents") do |form| %>
  <% if inventory_item.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(inventory_item.errors.count, "error") %> prohibited this inventory item from being saved:</h2>

      <ul class="list-disc ml-6">
        <% inventory_item.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="text-gray-600 my-5">
    <%= form.label :ingredient_id, "Ingredient" %>
    <%= form.collection_select :ingredient_id, current_user.ingredients, :id, :name,
      { prompt: "Select an ingredient" },
      { class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" } %>
  </div>

  <div class="text-gray-600 my-5">
    <%= form.label :purchase_date, "Purchase date" %>
    <%= form.date_field :purchase_date,
      class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="text-gray-600 my-5">
    <%= form.label :brand %>
    <%= form.text_field :brand,
      class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="text-gray-600 my-5">
    <%= form.label :size, "Size" %>
    <%= form.text_field :size,
      class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="text-gray-600 my-5">
    <%= form.label :location, "Storage location" %>
    <%= form.text_field :location,
      class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="text-gray-600 my-5">
    <%= form.label :notes %>
    <%= form.text_area :notes, rows: 5,
      class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <%# Only include this if your model has: has_one_attached :photo %>
  <div class="text-gray-600 my-5">
    <%= form.label :photo %>
    <%= form.file_field :photo,
      class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
  </div>

  <div class="inline">
    <%= form.submit "Save inventory item",
      class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>
  </div>
<% end %>

