<% content_for :title, "Inventory Item View" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="text-5xl font-extrabold text-indigo-300 tracking-wide">Inventory Item View</h1>
  <% content_for :title, "Showing inventory item" %>

<div class="container mx-auto mt-12 px-6">
  <% if notice.present? %>
    <p class="mb-6 text-indigo-700 font-medium"><%= notice %></p>
  <% end %>

  <!-- Main Card -->
  <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] relative hover:shadow-2xl transition duration-300 max-w-3xl">

    <div class="mb-4">
      <span class="inline-block px-4 py-1 text-xs font-semibold
                   text-indigo-800 uppercase bg-purple-200 rounded-full">
        Inventory Item
      </span>
    </div>

    <h2 class="text-2xl font-bold text-indigo-900 mb-3">
      <%= @inventory_item.ingredient&.name || "Inventory Item" %>
    </h2>

    <% if @inventory_item.ingredient&.category.present? %>
      <p class="text-gray-600 mb-2">
        Category:
        <span class="font-semibold text-gray-700">
          <%= @inventory_item.ingredient.category %>
        </span>
      </p>
    <% end %>

    <div class="text-gray-600 mb-6 space-y-2">
      <% if @inventory_item.brand.present? %>
        <p>Brand: <span class="font-semibold text-gray-700"><%= @inventory_item.brand %></span></p>
      <% end %>

      <% if @inventory_item.size.present? %>
        <p>Size: <span class="font-semibold text-gray-700"><%= @inventory_item.size %></span></p>
      <% end %>

      <% if @inventory_item.location.present? %>
        <p>Location: <span class="font-semibold text-gray-700"><%= @inventory_item.location %></span></p>
      <% end %>

      <% if @inventory_item.purchase_date.present? %>
        <p>Purchase date:
          <span class="font-semibold text-gray-700">
            <%= @inventory_item.purchase_date.strftime("%b %d, %Y") %>
          </span>
        </p>
      <% end %>

      <% if @inventory_item.notes.present? %>
        <p>Notes: <span class="font-semibold text-gray-700"><%= @inventory_item.notes %></span></p>
      <% end %>
    </div>


    <!-- ACTION BUTTONS (same structure as batches) -->
    <div class="flex flex-wrap gap-4 border-t-2 border-purple-200 pt-6 mt-6">

      <%= link_to "Edit this inventory item",
        edit_inventory_item_path(@inventory_item),
        class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

      <%= link_to "Back to inventory items",
        inventory_items_path,
        class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

      <%= button_to "Destroy this inventory item",
        @inventory_item,
        method: :delete,
        form_class: "inline",
        class: "bg-[#630436] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-125 transition duration-200",
        data: { turbo_confirm: "Are you sure?" } %>

    </div>
  </div>
</div>
</div>