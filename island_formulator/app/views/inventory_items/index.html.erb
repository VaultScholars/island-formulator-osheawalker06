<% content_for :title, "Inventory" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-emerald-50 mb-5 text-emerald-700 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center mb-8">
    <h1 class="text-4xl font-extrabold text-slate-100">Inventory</h1>
    <%= link_to "New inventory item", new_inventory_item_path,
      class: "rounded-xl px-4 py-2 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold" %>
  </div>

  <% if @inventory_items.any? %>
    <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
      <% @inventory_items.each do |item| %>
        <%= render item %>
      <% end %>
    </div>
  <% else %>
    <div class="bg-slate-900/40 border border-white/10 rounded-2xl p-10 text-center">
      <p class="text-slate-200 text-xl font-semibold">No inventory items yet.</p>
      <p class="text-slate-400 mt-2">Track purchases so your dashboard stays accurate.</p>
      <div class="mt-6">
        <%= link_to "Add your first inventory item", new_inventory_item_path,
          class: "rounded-xl px-5 py-3 bg-emerald-600 hover:bg-emerald-500 text-white font-semibold" %>
      </div>
    </div>
  <% end %>
</div>