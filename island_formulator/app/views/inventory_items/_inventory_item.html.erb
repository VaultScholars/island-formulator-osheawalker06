<% content_for :title, "Showing inventory item" %>

<div class="container mx-auto mt-12 px-6">
  <% if notice.present? %>
    <p class="mb-6 text-indigo-700 font-medium"><%= notice %></p>
  <% end %>

  <!-- Main Card (same as batches/ingredients card vibe) -->
  <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] relative hover:shadow-2xl transition duration-300 max-w-3xl">

    <div class="mb-4">
      <span class="inline-block px-4 py-1 text-xs font-semibold
                   text-indigo-800 uppercase bg-purple-200 rounded-full">
        Inventory Item
      </span>
    </div>

    <!-- Optional: show ingredient name/category if you have ingredient association -->
    <h2 class="text-2xl font-bold text-indigo-900 mb-3">
      <%= @inventory_item.ingredient&.name || "Inventory Item" %>
    </h2>

    <% if @inventory_item.ingredient&.category.present? %>
      <p class="text-gray-600 mb-2">
        Category: <span class="font-semibold text-gray-700"><%= @inventory_item.ingredient.category %></span>
      </p>
    <% end %>

    <div class="text-gray-600 mb-6 space-y-2">
      <% if @inventory_item.brand.present? %>
        <p>Brand: <span class="font-semibold text-gray-700"><%= @inventory_item.brand %></span></p>
      <% end %>

      <% if @inventory_item.size.present? %>
        <p>Size: <span class="font-semibold text-gray-700"><%= @inventory_item.size %></span></p>
      <% end %>

      <% if @inventory_item.location.present? %>
        <p>Location: <span class="font-semibold text-gray-700"><%= @inventory_item.location %></span></p>
      <% end %>

      <% if @inventory_item.purchase_date.present? %>
        <p>Purchase date: <span class="font-semibold text-gray-700"><%= @inventory_item.purchase_date.strftime("%b %d, %Y") %></span></p>
      <% end %>

      <% if @inventory_item.notes.present? %>
        <p>Notes: <span class="font-semibold text-gray-700"><%= @inventory_item.notes %></span></p>
      <% end %>
    </div>
  </div>
</div>