<% content_for :title, "Batch View" %>

<div class="container mx-auto mt-12 px-6">
  <div class="flex justify-between items-center mb-12">
    <h1 class="text-5xl font-extrabold text-indigo-300 tracking-wide">
      Batch View
    </h1>
  </div>

  <% if notice.present? %>
    <p class="mb-6 text-indigo-700 font-medium"><%= notice %></p>
  <% end %>

  <!-- Main Card (match Ingredient card vibe) -->
  <div class="bg-indigo-50 border-4 border-purple-300 shadow-lg p-8 rounded-[60px] relative hover:shadow-2xl transition duration-300 max-w-3xl">
    <div class="mb-4">
      <span class="inline-block px-4 py-1 text-xs font-semibold text-indigo-800 uppercase bg-purple-200 rounded-full">
        Batch Log
      </span>
    </div>

    <h2 class="text-2xl font-bold text-indigo-900 mb-3">
      <%= @batch.recipe&.title || "Unknown recipe" %>
    </h2>

    <p class="text-gray-600 mb-6">
      Made on:
      <span class="font-semibold text-gray-700">
        <%= @batch.made_on&.strftime("%b %d, %Y") %>
      </span>
    </p>

    <div class="border-t-2 border-purple-200 pt-6">
      <h3 class="text-sm font-semibold text-indigo-800 uppercase tracking-wide mb-3">
        Production Notes
      </h3>

      <% if @batch.notes.present? %>
        <div class="text-gray-600 leading-relaxed whitespace-pre-line">
          <%= @batch.notes %>
        </div>
      <% else %>
        <p class="text-gray-500 italic">No notes added.</p>
      <% end %>
    </div>

    <div class="flex flex-wrap items-center gap-6 mt-8">
      <%= link_to "Edit this batch", edit_batch_path(@batch),
        class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

      <%= link_to "Back to batches", batches_path,
        class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

      <% if @batch.recipe.present? %>
        <%= link_to "View recipe", recipe_path(@batch.recipe),
          class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>

      <%= button_to "Destroy this batch", @batch,
        method: :delete,
        form_class: "inline",
        class: "bg-[#630436] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-125 transition duration-200",
        data: { turbo_confirm: "Are you sure?" } %>

      
      <% end %>
    </div>
  </div>
</div>