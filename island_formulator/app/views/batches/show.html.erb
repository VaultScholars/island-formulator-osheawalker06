<% content_for :title, "Batch Details" %>

<div class="max-w-3xl">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-6 text-green-600 font-medium rounded-md inline-block" id="notice">
      <%= notice %>
    </p>
  <% end %>

  <div class="bg-[#eef2ff] rounded-[2rem] border-2 border-[#c9a2ff] shadow-[0_15px_40px_rgba(0,0,0,0.25)] p-8">
    <div class="flex items-start justify-between gap-6">
      <div>
        <span class="inline-flex items-center rounded-full bg-[#e6dcff] px-3 py-1 text-xs font-bold text-indigo-700">
          BATCH LOG
        </span>

        <h1 class="mt-4 text-3xl font-extrabold text-indigo-900">
          <%= @batch.recipe&.title || "Unknown recipe" %>
        </h1>

        <p class="mt-2 text-sm text-gray-600">
          Made on: <span class="font-semibold text-gray-800"><%= @batch.made_on&.strftime("%b %d, %Y") %></span>
        </p>
      </div>

      <%= link_to "Back", batches_path,
        class: "text-sm font-semibold px-4 py-2 rounded-full bg-white border border-[#c9a2ff] text-indigo-700 hover:bg-[#f4f0ff] transition" %>
    </div>

    <div class="mt-6 border-t border-[#c9a2ff]/40 pt-6">
      <h2 class="text-sm font-extrabold text-indigo-700 uppercase tracking-wide">
        Production Notes
      </h2>

      <% if @batch.notes.present? %>
        <div class="mt-3 text-gray-800 leading-relaxed whitespace-pre-line">
          <%= @batch.notes %>
        </div>
      <% else %>
        <p class="mt-3 text-gray-500 italic">No notes added.</p>
      <% end %>
    </div>

    <div class="mt-8 flex flex-wrap gap-3">
      <%= link_to "Edit", edit_batch_path(@batch),
        class: "text-sm font-semibold px-5 py-3 rounded-full bg-[#b47cff] hover:bg-[#a96cff] text-white shadow transition" %>

      <%= button_to "Delete", @batch, method: :delete,
        class: "text-sm font-semibold px-5 py-3 rounded-full bg-[#7a003c] text-white hover:opacity-90 transition",
        data: { turbo_confirm: "Delete this batch log?" } %>

      <% if @batch.recipe.present? %>
        <%= link_to "View Recipe", recipe_path(@batch.recipe),
          class: "text-sm font-semibold px-5 py-3 rounded-full bg-white border border-[#c9a2ff] text-indigo-700 hover:bg-[#f4f0ff] transition" %>
      <% end %>
    </div>
  </div>
</div>