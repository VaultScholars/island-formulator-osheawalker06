<% content_for :title, "Edit Batch" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-gray-700 text-4xl">Edit Batch</h1>

  <%= render "form", batch: @batch %>

  <%= link_to "Show this batch", @batch, class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %>
  <%= link_to "Back to batches", batches_path,
    class: "bg-[#9E7BB5] text-white px-6 py-3 rounded-xl font-semibold shadow-md hover:brightness-110 transition duration-200" %></div>
